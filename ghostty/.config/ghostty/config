# Font configuration:
font-family = Hack
font-size = 14.5
font-feature = -calt

# Cursor:
cursor-invert-fg-bg = true
cursor-style-blink = false
cursor-click-to-move = true
adjust-cursor-thickness = 150%

# Background:
background-opacity = 0.90
background-blur-radius = 15

# Macos
macos-option-as-alt = true
keybind = global:ctrl+enter=toggle_quick_terminal

# Leader mode
keybind = ctrl+s>1=goto_tab:1
keybind = ctrl+s>2=goto_tab:2
keybind = ctrl+s>3=goto_tab:3
keybind = ctrl+s>4=goto_tab:4
keybind = ctrl+s>5=goto_tab:5
keybind = ctrl+s>6=goto_tab:6
keybind = ctrl+s>7=goto_tab:7
keybind = ctrl+s>8=goto_tab:8
keybind = ctrl+s>9=goto_tab:9
keybind = ctrl+s>==equalize_splits
keybind = ctrl+s>v=new_split:right
keybind = ctrl+s>s=new_split:down
keybind = ctrl+s>p=toggle_command_palette

# Misc:
theme = dark:riot-dark,light:riot-light
shell-integration = fish
